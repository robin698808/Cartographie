# ─── Déploiement Docker Compose (racine) ─────────────────────────────────
# Copier en .env et adapter :  cp .env.example .env

# PostgreSQL
POSTGRES_DB=cartographe
POSTGRES_USER=cartographe
POSTGRES_PASSWORD=change-moi-mot-de-passe-fort

# Clé de signature JWT — OBLIGATOIRE, générer avec :  openssl rand -hex 32
SECRET_KEY=change-moi-openssl-rand-hex-32

# Origines CORS autorisées (séparées par des virgules).
# Derrière le reverse proxy (même origine), laisser * suffit.
# En accès direct à l'API depuis un autre domaine, mettre l'URL publique du front :
#   CORS_ORIGINS=https://cartographe.mondomaine.fr
CORS_ORIGINS=*

# Durée de validité du token (minutes) — 10080 = 7 jours
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Port HTTP exposé publiquement (80 par défaut ; 443 via reverse proxy TLS externe)
HTTP_PORT=80

# URL publique du frontend — utilisée dans les liens de reset de mot de passe.
# Mettre le vrai domaine en prod :  https://cartographe.mondomaine.fr
FRONTEND_URL=http://localhost

# ─── SMTP (optionnel) ────────────────────────────────────────────────────
# Pour l'envoi réel des emails de réinitialisation de mot de passe.
# Si vide, le lien est simplement écrit dans les logs du backend.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

