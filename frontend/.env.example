# ─── Frontend (dev local sans reverse proxy) ─────────────────────────────
# En production (Docker Compose), ne rien définir : le front utilise des URLs
# relatives (/api, /ws) relayées par nginx.
#
# En dev, si le backend tourne sur un autre port, décommenter :
# VITE_API_URL=http://localhost:8001/api
# VITE_WS_URL=ws://localhost:8001
